# ============================================================
# SaaS MAPS - Variáveis de Ambiente
# Copie este arquivo como .env e preencha as credenciais
# ============================================================

# Supabase (obrigatório)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Google OAuth - Client ID (obrigatório para login Google)
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# Google Maps / Places API (opcional - melhora os resultados)
GOOGLE_MAPS_API_KEY=sua-chave-api-aqui

# OpenAI API (opcional - para enriquecimento de dados com IA)
OPENAI_API_KEY=sua-chave-api-aqui
OPENAI_MODEL=gpt-4o-mini

# Configurações do sistema
APP_NAME=SaaS Maps
APP_URL=http://localhost:5500