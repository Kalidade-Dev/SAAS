# ============================================================
# SaaS MAPS - Variáveis de Ambiente
# Copie este arquivo como .env e preencha as credenciais
# ============================================================

# Supabase (obrigatório)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Google OAuth - Client ID (obrigatório para login Google)
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# Google Maps / Places API (opcional - melhora significativamente os resultados)
# Habilite: Places API, Maps JavaScript API no Google Cloud Console
GOOGLE_MAPS_API_KEY=sua-chave-api-aqui

# IA para Enriquecimento de Dados (opcional)
# Provedores suportados: openai, gemini, mock (padrão)
# Sem API Key, o sistema usa enriquecimento local (mock)
AI_PROVIDER=mock
OPENAI_API_KEY=sua-chave-openai-aqui
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=sua-chave-gemini-aqui
GEMINI_MODEL=gemini-1.5-flash

# Configurações do sistema
APP_NAME=SaaS Maps
APP_URL=http://localhost:5500